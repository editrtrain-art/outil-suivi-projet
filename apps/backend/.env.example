# =========================================================================
# NEXUS V3 — Environment Variables
# =========================================================================
# Copy this file to `.env` and fill in real values.
# NEVER commit the actual `.env` file to version control.
# =========================================================================

# ── Database ────────────────────────────────────────────────────────────
# Async PostgreSQL DSN used by SQLAlchemy + asyncpg.
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/nexus

# Minimum number of connections kept alive in the pool (default: 2).
DATABASE_POOL_MIN=2

# Maximum number of connections the pool can open (default: 10).
DATABASE_POOL_MAX=10

# ── CORS ────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for cross-origin requests.
# In production, set this to your frontend's domain(s).
CORS_ORIGINS=["http://localhost:3000"]

# ── Clerk Authentication ────────────────────────────────────────────────
# Backend secret key issued by Clerk (Dashboard → API Keys).
CLERK_SECRET_KEY=

# Publishable key used for client-side SDK initialisation.
CLERK_PUBLISHABLE_KEY=

# URL to Clerk's JWKS endpoint for JWT signature verification.
# Typically: https://<your-clerk-instance>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=

# ── LLM / AI Engine ────────────────────────────────────────────────────
# Provider backend: ollama | openai | anthropic
LLM_PROVIDER=ollama

# Base URL of the LLM-compatible API.
# Ollama default: http://localhost:11434/v1
# OpenAI: https://api.openai.com/v1
LLM_BASE_URL=http://localhost:11434/v1

# API key for the LLM provider. Ollama doesn't require a real key.
LLM_API_KEY=ollama

# Model identifier passed to the LLM provider.
# Examples: llama3:8b, gpt-4o, claude-3-sonnet
LLM_MODEL=llama3:8b

# ── General ─────────────────────────────────────────────────────────────
# Runtime environment: development | staging | production
ENVIRONMENT=development

# Python log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
